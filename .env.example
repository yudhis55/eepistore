# Application
NODE_ENV=development
AUTH_SECRET=YOUR_AUTH_SECRET_HERE
AUTH_URL=http://localhost:3000

# Database (dev: docker compose postgres on port 5433 to avoid host conflict)
DATABASE_URL=YOUR_DATABASE_URL_HERE

# Storage (dev: MinIO, prod: S3)
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BUCKET=eepistore-public
S3_PRIVATE_BUCKET=eepistore-private
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9000/eepistore-public
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Email (dev: MailHog, prod: SES)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eepistore.local
